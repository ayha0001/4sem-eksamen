---
import Layout from "../layouts/Layout.astro";
import HeroLille from "../components/generelt/HeroLille.astro";
import FooterMedlem from "../components/generelt/FooterMedlem.astro";
import UdtalelseSektion from "../components/udtalelser/UdtalelseSektion.astro";
import Deler from "../components/generelt/Deler.astro";
import DelerStreg from "../components/generelt/DelerStreg.astro";
import ProjektSektion from "../components/afsnit/ProjektSektion.astro";
import TekstCenter from "../components/afsnit/TekstCenter.astro";
---

<Layout pagetitle="Udtalelser">
  <HeroLille
    titel="UDTALELSER"
    billede="/assets/img/udt-hero.webp"
    farve="text-background1"
  />
  <Deler ws="m" />
  <TekstCenter
    titel="Vil du læse mere om os?"
    tekst="Vi sætter pris på, når andre er interesserede i hvad vi laver. Herunder kan du se og læse mere om vores organisation og arbejde - set gennem andres øjne. "
  />
  <Deler ws="xs" />
  <UdtalelseSektion />
  <Deler ws="xs" />
  <DelerStreg src="/assets/grafik/divider-grey.svg" />
  <ProjektSektion columns={2} />
  <Deler ws="m" />
  <FooterMedlem />
</Layout>
