---
const { text = "HJÆLP DIN NÆSTE" } = Astro.props;
---

<div class="bg-background1 w-full overflow-hidden py-2">
  <div class="flex items-center justify-between gap-6 px-6 whitespace-nowrap">
    {
      Array.from({ length: 9 }).map((_, index) => (
        <span
          class={`font-body text-m-p-big lg:text-p-big text-secondary tracking-wide uppercase ${
            index % 2 === 0 ? "font-normal" : "font-semibold"
          }`}
        >
          {text}
        </span>
      ))
    }
  </div>
</div>
