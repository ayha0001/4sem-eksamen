---
import Knap from "./Knap.astro";
import Link from "./Link.astro";

const {} = Astro.props;
---

<header
  id="site-header"
  class="bg-background1 fixed top-0 z-50 flex w-full flex-col shadow"
>
  <div class="flex w-full items-center px-6 py-4">
    <a href="/" class="inline-flex flex-shrink-0 items-center gap-4">
      <img src="/assets/grafik/logo_hænder.svg" alt="Logo" class="h-8" />
      <span
        id="wordmark"
        class="font-wordmark text-primary hidden text-[30px] font-semibold text-nowrap min-[1200px]:inline"
      >
        HJÆLP DiN NÆSTE
      </span>
    </a>

    <nav class="hidden w-full items-center justify-end gap-6 min-[1200px]:flex">
      <Link
        href="/"
        variant="headerlink-dropdown"
        size="medium"
        data-mega-trigger="projekter"
        aria-haspopup="true"
      >
        Projekter
      </Link>

      <Link
        href="/"
        variant="headerlink-dropdown"
        size="medium"
        data-mega-trigger="omos"
        aria-haspopup="true"
      >
        Om os
      </Link>

      <Link href="/bliv-frivillig" variant="headerlink" size="medium"
        >Bliv frivillig</Link
      >
      <Link href="/partnere" variant="headerlink" size="medium"
        >Bliv partner</Link
      >
      <Link
        href="/"
        variant="headerlink-dropdown"
        size="medium"
        data-mega-trigger="doner"
        aria-haspopup="true"
      >
        Donér
      </Link>
      <Link href="/gennemsigtighed" variant="headerlink" size="medium"
        >Gennemsigtighed</Link
      >
      <Link href="/kontakt-os" variant="headerlink" size="medium"
        >Kontakt os</Link
      >
      <Knap href="/stoet-os" variant="primary" size="medium">STØT NU</Knap>
    </nav>

    <!-- STØT NU button centered (mobile only) -->
    <div
      id="center-button"
      class="flex hidden flex-1 justify-center max-[1149px]:flex"
    >
      <Knap href="/stoet-os" variant="primary" size="small"> STØT NU </Knap>
    </div>

    <!-- Burger menu toggle button (mobile only, pushed right) -->
    <button
      id="burger-toggle"
      class="ml-auto flex hidden h-8 w-8 cursor-pointer items-center justify-center max-[1149px]:flex"
      aria-label="Åbn menu"
      aria-expanded="false"
    >
      <img
        id="burger-icon"
        src="/assets/grafik/burger-linje.svg"
        alt=""
        class="h-6 w-6 transition-opacity duration-300"
      />
    </button>
  </div>
</header>
<!-- Spacer to prevent content being hidden under fixed header -->
<div class="block h-19 w-full max-[1199px]:h-16"></div>

<!-- Mobile menu panel -->
<div
  id="mobile-menu"
  class="bg-background1 fixed top-0 right-0 z-60 hidden h-screen w-screen translate-x-full transform overflow-y-auto transition-transform duration-300 max-[1149px]:block"
>
  <div class="flex flex-col gap-8 px-5 py-4">
    <!-- Mobile brand + close -->
    <div class="flex items-center justify-between">
      <a href="/" class="inline-flex items-center gap-4">
        <img src="/assets/grafik/logo_hænder.svg" alt="Logo" class="h-8" />
        <span
          class="font-wordmark text-primary text-[30px] font-semibold text-nowrap"
        >
          HJÆLP DiN NÆSTE
        </span>
      </a>
      <button
        id="mobile-menu-close"
        class="flex h-8 w-8 items-center justify-center"
        aria-label="Luk menu"
      >
        <img
          src="/assets/grafik/burger-linje-open.svg"
          alt=""
          class="h-6 w-6"
        />
      </button>
    </div>

    <!-- Divider -->
    <img src="/assets/grafik/deler-title.svg" alt="" class="w-75" />

    <!-- Navigation items -->
    <nav class="flex flex-col gap-6">
      <!-- Projekter with submenu -->
      <div>
        <button
          class="mobile-submenu-toggle group text-secondary flex w-full items-center justify-between transition-opacity hover:opacity-70"
          data-submenu="projekter-mobile"
          aria-expanded="false"
        >
          <span class="text-p-big">Projekter</span>
          <svg
            class="h-4 w-4 transition-transform duration-300 group-aria-expanded:rotate-180"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>
        <div
          id="projekter-mobile"
          class="border-secondary/30 mt-0 flex max-h-0 flex-col gap-3 overflow-hidden border-l pl-4 opacity-0 transition-all duration-300"
