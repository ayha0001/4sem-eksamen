<script is:inline type="module">
  // Burger menu toggle
  const burgerToggle = document.getElementById("burger-toggle");
  const burgerIcon = document.getElementById("burger-icon");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileMenuOverlay = document.getElementById("mobile-menu-overlay");
  const mobileMenuClose = document.getElementById("mobile-menu-close");
  const centerButton = document.getElementById("center-button");
  let isMobileMenuOpen = false;

  const toggleMobileMenu = () => {
    isMobileMenuOpen = !isMobileMenuOpen;

    if (isMobileMenuOpen) {
      // Show mobile menu
      mobileMenu.classList.remove("translate-x-full");
      mobileMenuOverlay.classList.remove("hidden");

      // Hide center button
      centerButton.classList.add("hidden");

      // Animate burger icon
      burgerIcon.style.opacity = "0";
      setTimeout(() => {
        burgerIcon.src = "/assets/grafik/burger-linje-open.svg";
        burgerIcon.style.opacity = "1";
      }, 150);

      burgerToggle.setAttribute("aria-expanded", "true");
      document.body.style.overflow = "hidden";
    } else {
      // Hide mobile menu
      mobileMenu.classList.add("translate-x-full");
      mobileMenuOverlay.classList.add("hidden");

      // Show center button
      centerButton.classList.remove("hidden");

      // Animate burger icon back
      burgerIcon.style.opacity = "0";
      setTimeout(() => {
        burgerIcon.src = "/assets/grafik/burger-linje.svg";
        burgerIcon.style.opacity = "1";
      }, 150);

      burgerToggle.setAttribute("aria-expanded", "false");
      document.body.style.overflow = "";
    }
  };

  if (burgerToggle && burgerIcon && mobileMenu) {
    burgerToggle.addEventListener("click", toggleMobileMenu);
  }

  // Close menu on overlay click
  if (mobileMenuOverlay) {
    mobileMenuOverlay.addEventListener("click", () => {
      if (isMobileMenuOpen) toggleMobileMenu();
    });
  }

  // Close menu on close button click
  if (mobileMenuClose) {
    mobileMenuClose.addEventListener("click", () => {
      if (isMobileMenuOpen) toggleMobileMenu();
    });
  }

  // Submenu toggles
  const submenuToggles = document.querySelectorAll(".mobile-submenu-toggle");

  const openSubmenu = (submenu) => {
    submenu.classList.remove("mt-0", "max-h-0", "opacity-0");
    submenu.classList.add("mt-4", "opacity-100");
    submenu.style.maxHeight = submenu.scrollHeight + "px";
  };

  const closeSubmenu = (submenu) => {
    submenu.style.maxHeight = submenu.scrollHeight + "px";
    requestAnimationFrame(() => {
      submenu.classList.remove("mt-4", "opacity-100");
      submenu.classList.add("mt-0", "max-h-0", "opacity-0");
      submenu.style.maxHeight = "0px";
    });
  };

  submenuToggles.forEach((toggle) => {
    toggle.addEventListener("click", (e) => {
      e.preventDefault();
      const submenuId = toggle.getAttribute("data-submenu");
      const submenu = document.getElementById(submenuId);

      if (submenu) {
        const isExpanded = toggle.getAttribute("aria-expanded") === "true";
        toggle.setAttribute("aria-expanded", String(!isExpanded));

        if (isExpanded) {
          closeSubmenu(submenu);
        } else {
          openSubmenu(submenu);
        }
      }
    });
  });

  // Close menu when clicking on a link
  const mobileMenuLinks = mobileMenu.querySelectorAll("a");
  mobileMenuLinks.forEach((link) => {
    // Don't close for submenu toggle buttons or social links
    if (!link.closest(".mobile-submenu-toggle") && link.target !== "_blank") {
      link.addEventListener("click", () => {
        if (isMobileMenuOpen) toggleMobileMenu();
      });
    }
  });
</script>

<script is:inline type="module">
  const header = document.getElementById("site-header");
  const megaMenu = document.getElementById("mega-menu");
  const triggers = document.querySelectorAll("[data-mega-trigger]");
  const panels = document.querySelectorAll("[data-mega-panel]");

  if (header && megaMenu && triggers.length) {
    const indicator = document.getElementById("mega-indicator");

    const positionMegaMenu = () => {
      const headerRect = header.getBoundingClientRect();
      megaMenu.style.top = `${headerRect.bottom}px`;
    };

    positionMegaMenu();
    window.addEventListener("resize", positionMegaMenu);

    const showPanel = (key, triggerEl) => {
      positionMegaMenu();
      panels.forEach((panel) => panel.classList.add("hidden"));

      const activePanel = document.querySelector(`[data-mega-panel="${key}"]`);

      if (activePanel) {
        activePanel.classList.remove("hidden");
        activePanel.classList.add("grid");
      }

      // Markér aktiv trigger så Link-komponenten kan rotere pilen
      triggers.forEach((trigger) => trigger.classList.remove("mega-open"));
      if (triggerEl) {
        triggerEl.classList.add("mega-open");
      }

      // Mål det faktiske indhold så animationen er præcis
      megaMenu.style.maxHeight = megaMenu.scrollHeight + "px";
      megaMenu.classList.remove("opacity-0", "pointer-events-none");
      megaMenu.classList.add("opacity-100", "pointer-events-auto");
      megaMenu.setAttribute("aria-hidden", "false");

      if (indicator && triggerEl) {
        const rect = triggerEl.getBoundingClientRect();
        const headerRect = header.getBoundingClientRect();
        indicator.style.left = rect.left - headerRect.left - 6 + "px";
        indicator.style.width = rect.width + "px";
      }
    };

    const hideMenu = () => {
      megaMenu.style.maxHeight = "0";
      megaMenu.classList.add("opacity-0", "pointer-events-none");
      megaMenu.classList.remove("opacity-100", "pointer-events-auto");
      megaMenu.setAttribute("aria-hidden", "true");
      triggers.forEach((trigger) => trigger.classList.remove("mega-open"));
      // Vent til animation er færdig før panels skjules
      megaMenu.addEventListener(
        "transitionend",
        () => {
          if (
            megaMenu.style.maxHeight === "0px" ||
            megaMenu.style.maxHeight === "0"
          ) {
            panels.forEach((panel) => panel.classList.add("hidden"));
          }
        },
        { once: true },
      );
    };

    let hideTimeout;

    const scheduleHide = () => {
      clearTimeout(hideTimeout);
      hideTimeout = setTimeout(() => {
        hideMenu();
      }, 100); // 100ms buffer så man kan nå fra trigger til menu
    };

    const cancelHide = () => {
      clearTimeout(hideTimeout);
    };

    triggers.forEach((trigger) => {
      trigger.addEventListener("mouseenter", () => {
        showPanel(trigger.dataset.megaTrigger, trigger);
        cancelHide();
      });
      trigger.addEventListener("focus", () => {
        showPanel(trigger.dataset.megaTrigger, trigger);
        cancelHide();
      });
      trigger.addEventListener("click", (event) => {
        event.preventDefault();
      });
      trigger.addEventListener("mouseleave", scheduleHide);
    });

    // Luk menuen når man hover over links i NAV (topbar) som IKKE er dropdown-triggers
    const nav = header.querySelector("nav");
    if (nav) {
      nav.querySelectorAll("a, button").forEach((el) => {
        if (!el.dataset.megaTrigger) {
          el.addEventListener("mouseenter", hideMenu);
        }
      });
    }

    // Hvis musen forlader header ELLER megamenu, så planlæg lukning
    header.addEventListener("mouseleave", scheduleHide);
    megaMenu.addEventListener("mouseleave", scheduleHide);
    // Hvis musen går ind i header eller menu, annuller lukning
    header.addEventListener("mouseenter", cancelHide);
    megaMenu.addEventListener("mouseenter", cancelHide);
  }
</script>
