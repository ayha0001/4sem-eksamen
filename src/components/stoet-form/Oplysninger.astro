---
import Link from '../generelt/Link.astro';
---

<section class="container mx-auto px-4 max-w-2xl mt-2 lg:mt-8">
        
<div class="w-full max-w-sm mx-auto mt-14 mb-8 font-body lg:max-w-xl lg:mb-10">

  <!-- Tekst -->
  <div class="flex justify-between text-secondary mt-6">
    <p>Vælg</p>
    <p>Oplysninger</p>
    <p>Betaling</p>
    <p>Bekræftelse</p>
  </div>

  <!-- Linje + cirkler -->
  <div class="relative flex justify-between items-center mt-4">

    <!-- Linje -->
    <div class="absolute left-0 right-0 top-1/2 h-0.5 bg-primary -translate-y-1/2"></div>

    <!-- Cirkel 1 -->
    <div class="relative z-10 flex h-8 w-8 items-center justify-center rounded-full border-2 border-secondary bg-background1 text-primary text-p-small lg:h-6 lg:w-6 lg:text-m-p-small">
      1
    </div>

    <!-- Cirkel 2 -->
    <div class="relative z-10 flex h-8 w-8 items-center justify-center rounded-full border-2 border-secondary bg-background1 text-primary text-p-small lg:h-6 lg:w-6 lg:text-m-p-small">
      2
    </div>

    <!-- Cirkel 3 -->
    <div class="relative z-10 flex h-8 w-8 items-center justify-center rounded-full border-2 border-secondary bg-background1 text-primary text-p-small lg:h-6 lg:w-6 lg:text-m-p-small">
      3
    </div>

    <!-- Cirkel 4 -->
    <div class="relative z-10 flex h-8 w-8 items-center justify-center rounded-full border-2 border-secondary bg-background1 text-primary text-p-small lg:h-6 lg:w-6 lg:text-m-p-small">
      4
    </div>

  </div>
</div>

  <form class="mx-auto flex w-full max-w-2xl flex-col gap-6">
  
    <p class="mt-6 text-m-p-big lg:text-p-big">
      Indtast dine oplysninger
    </p>

    <div class="flex flex-col gap-5">
      <label class="flex flex-col gap-2 text-m-p-big lg:text-p-big">
        <span>For- og efternavn<span class="text-primary">*</span></span>
        <input
          type="text"
          placeholder="Tekst"
          required
          class="w-full rounded-md border-2 border-secondary bg-background1 px-5 py-3 text-m-p-big focus:outline-none lg:text-p-big"
        />
      </label>

      <label class="flex flex-col gap-2 text-m-p-big lg:text-p-big">
        <span>E-mail<span class="text-primary">*</span></span>
        <input
          type="email"
          placeholder="Tekst"
          required
          class="w-full rounded-md border-2 border-secondary bg-background1 px-5 py-3 text-m-p-big focus:outline-none lg:text-p-big"
        />
      </label>

      <label class="flex flex-col gap-2 text-m-p-big lg:text-p-big">
        <span>Telefon<span class="text-primary">*</span></span>
        <input
          type="tel"
          placeholder="Tekst"
          required
          class="w-full rounded-md border-2 border-secondary bg-background1 px-5 py-3 text-m-p-big focus:outline-none lg:text-p-big"
        />
      </label>
    </div>

    <!-- Checkboxes -->
    <div class="mt-4 flex flex-col gap-4 rounded-md p-5">
      <label class="flex cursor-pointer items-start gap-3 text-m-p-small text-secondary lg:text-p-big">
        <input
          type="checkbox"
          class="mt-1 h-5 w-5 accent-primary"
        />
        <span>Ja tak, jeg ønsker skattefradrag</span>
      </label>

      <label class="flex cursor-pointer items-start gap-3 text-m-p-small text-secondary lg:text-p-big">
        <input
          type="checkbox"
          required
          class="mt-1 h-5 w-5 accent-primary"
        />
        <span>
          Jeg accepterer
          <a href="#" class="font-semibold text-primary underline">
            følgende betingelser
          </a>
          <span class="text-primary">*</span>
        </span>
      </label>

      <label class="flex cursor-pointer items-start gap-3 text-m-p-small text-secondary lg:text-p-big">
        <input
          type="checkbox"
          required
          class="mt-1 h-5 w-5 accent-primary"
        />
        <span>
          Jeg har læst
          <a href="#" class="font-semibold text-primary underline">
            persondata
          </a>
          <span class="text-primary">*</span>
        </span>
      </label>
    </div>

   <Link href="/betaling" variant="primary2" size="medium">
  Videre
</Link>
    </div>
  </form>
</section>