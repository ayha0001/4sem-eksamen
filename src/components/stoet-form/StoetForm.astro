---
import Link from '../generelt/Link.astro';

interface Props {
  currentStep?: number;
}

const { currentStep = 1 } = Astro.props;
---

<section class="container mx-auto mt-2 max-w-2xl px-4 lg:mt-8">

  <!-- STEPS -->
  <div class="mx-auto mt-14 mb-8 w-full max-w-sm font-body lg:mb-10 lg:max-w-xl">

    <!-- Tekst -->
    <div class="mb-3 flex justify-between text-m-p-small text-secondary lg:text-p-big">
      <p>Vælg</p>
      <p>Oplysninger</p>
      <p>Betaling</p>
      <p>Bekræftelse</p>
    </div>

    <!-- Linje + cirkler -->
    <div class="relative flex items-center justify-between">

      <!-- Linje -->
      <div class="absolute top-1/2 left-0 right-0 h-0.5 -translate-y-1/2 bg-primary"></div>

      <!-- Cirkel 1 -->
      <div
        class:list={[
          "relative z-10 flex h-6 w-6 items-center justify-center rounded-full border-2 text-m-p-small lg:text-p-small",
          currentStep >= 1
            ? "border-primary bg-primary text-background1"
            : "border-secondary bg-background1 text-primary"
        ]}
      >
        1
      </div>

      <!-- Cirkel 2 -->
      <div
        class:list={[
          "relative z-10 flex h-6 w-6 items-center justify-center rounded-full border-2 text-m-p-small lg:text-p-small",
          currentStep >= 2
            ? "border-primary bg-primary text-background1"
            : "border-secondary bg-background1 text-primary"
        ]}
      >
        2
      </div>

      <!-- Cirkel 3 -->
      <div
        class:list={[
          "relative z-10 flex h-6 w-6 items-center justify-center rounded-full border-2 text-m-p-small lg:text-p-small",
          currentStep >= 3
            ? "border-primary bg-primary text-background1"
            : "border-secondary bg-background1 text-primary"
        ]}
      >
        3
      </div>

      <!-- Cirkel 4 -->
      <div
        class:list={[
          "relative z-10 flex h-6 w-6 items-center justify-center rounded-full border-2 text-m-p-small lg:text-p-small",
          currentStep >= 4
            ? "border-primary bg-primary text-background1"
            : "border-secondary bg-background1 text-primary"
        ]}
      >
        4
      </div>

    </div>
  </div>

  <!-- FORM -->
  <form class="mx-auto flex w-full max-w-xl flex-col gap-8 font-body">

    <!-- Vælg donationstype -->
    <div>
      <p class="mb-3 text-m-p-big text-secondary lg:text-p-big">
        Vælg donations type
      </p>

      <div class="flex flex-wrap gap-x-6 gap-y-3">
        <label class="flex cursor-pointer items-center gap-2 text-m-p-big text-secondary lg:text-p-big">
          <input type="radio" name="donationstype" value="engang" class="h-6 w-6 accent-primary" />
          Engangsdonation
        </label>

        <label class="flex cursor-pointer items-center gap-2 text-m-p-big text-secondary lg:text-p-big">
          <input type="radio" name="donationstype" value="aarligt" checked class="h-6 w-6 accent-primary" />
          Årligt medlemskab
        </label>

        <label class="flex cursor-pointer items-center gap-2 text-m-p-big text-secondary lg:text-p-big">
          <input type="radio" name="donationstype" value="maanedligt" class="h-6 w-6 accent-primary" />
          Månedligt medlemskab
        </label>
      </div>
    </div>

    <!-- Beløb -->
    <div>
      <p class="mb-3 text-m-p-big text-secondary lg:text-p-big">
        Vælg beløb
      </p>

      <div class="grid grid-cols-3 gap-2">

        <label class="block cursor-pointer">
          <input type="radio" name="belob" value="89" checked class="peer sr-only" />
          <span class="flex min-h-12 h-full items-center justify-center rounded-lg border-2 border-secondary bg-background1 px-4 py-3 text-center text-m-p-big text-secondary transition duration-200 hover:bg-secondary hover:text-white peer-checked:bg-secondary peer-checked:text-white lg:text-p-big">
            89 DKK
          </span>
        </label>

        <label class="block cursor-pointer">
          <input type="radio" name="belob" value="149" class="peer sr-only" />
          <span class="flex min-h-12 h-full items-center justify-center rounded-lg border-2 border-secondary bg-background1 px-4 py-3 text-center text-m-p-big text-secondary transition duration-200 hover:bg-secondary hover:text-white peer-checked:bg-secondary peer-checked:text-white lg:text-p-big">
            149 DKK
          </span>
        </label>

        <label class="block cursor-pointer">
          <input type="radio" name="belob" value="299" class="peer sr-only" />
          <span class="flex min-h-12 h-full items-center justify-center rounded-lg border-2 border-secondary bg-background1 px-4 py-3 text-center text-m-p-big text-secondary transition duration-200 hover:bg-secondary hover:text-white peer-checked:bg-secondary peer-checked:text-white lg:text-p-big">
            299 DKK
          </span>
        </label>

      </div>

      <input
        type="text"
        name="andetbeloeb"
        placeholder="Andet beløb"
        inputmode="numeric"
        class="mt-2 w-full rounded-md border-2 border-secondary bg-background1 px-4 py-3 text-center text-m-p-big text-secondary placeholder:text-secondary focus:outline-none lg:text-p-big"
      />
    </div>

    <!-- Betalingstype -->
    <div>
      <p class="mb-3 text-m-p-big text-secondary lg:text-p-big">
        Vælg betalingstype
      </p>

      <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6">
        <label class="flex cursor-pointer items-center gap-2 text-m-p-big text-secondary lg:text-p-big">
          <input type="radio" name="payment" value="mobilepay" checked class="h-6 w-6 accent-primary" />
          MobilePay
        </label>

        <label class="flex cursor-pointer items-center gap-2 text-m-p-big text-secondary lg:text-p-big">
          <input type="radio" name="payment" value="kort" class="h-6 w-6 accent-primary" />
          Betalingskort
        </label>
      </div>
    </div>

    <Link href="/oplysninger-form" variant="primary2" size="medium">
      Videre
    </Link>

  </form>
</section>