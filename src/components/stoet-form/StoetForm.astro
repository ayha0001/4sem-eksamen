---
import Knap from '../generelt/Knap.astro';
---

<section class=" container mx-auto px-4 max-w-2xl mt-2 lg:mt-4">
        
		
        <!-- STEPS -->
<div class="w-full max-w-xl mx-auto mb-10 font-body">

  <!-- Tekst -->
  <div class="flex justify-between text-m-p-small lg:text-p-big text-secondary mb-3">
    <p>Vælg</p>
    <p>Oplysninger</p>
    <p>Betaling</p>
    <p>Bekræftelse</p>
  </div>

  <!-- Linje + cirkler -->
  <div class="relative flex justify-between items-center">

    <!-- Linje -->
    <div class="absolute left-0 right-0 top-1/2 h-0.5 bg-primary -translate-y-1/2"></div>

    <!-- Cirkel 1 -->
    <div class="relative z-10 flex h-6 w-6 items-center justify-center rounded-full border-2 border-secondary bg-background1 text-primary text-m-p-small lg:text-p-small">
      1
    </div>

    <!-- Cirkel 2 -->
    <div class="relative z-10 flex h-6 w-6 items-center justify-center rounded-full border-2 border-secondary bg-background1 text-primary text-m-p-small lg:text-p-small">
      2
    </div>

    <!-- Cirkel 3 -->
    <div class="relative z-10 flex h-6 w-6 items-center justify-center rounded-full border-2 border-secondary bg-background1 text-primary text-m-p-small lg:text-p-small">
      3
    </div>

    <!-- Cirkel 4 -->
    <div class="relative z-10 flex h-6 w-6 items-center justify-center rounded-full border-2 border-secondary bg-background1 text-primarytext-m-p-small lg:text-p-small">
      4
    </div>

  </div>
</div>

      <form class="mx-auto flex w-full max-w-xl flex-col gap-8 font-body">

  <!-- Vælg donationstype -->
  <div>
    <p class="mb-3 text-m-p-big lg:text-p-big text-secondary">
      Vælg donations typé
    </p>

    <div class="flex flex-wrap gap-x-6 gap-y-3">
      <label class="flex cursor-pointer items-center gap-2 text-m-p-big lg:text-p-big text-secondary">
        <input type="radio" name="donationstype" value="engang" class="h-6 w-6 accent-primary" />
        Engangsdonation
      </label>

      <label class="flex cursor-pointer items-center gap-2 text-m-p-big lg:text-p-big text-secondary">
        <input type="radio" name="donationstype" value="aarligt" checked class="h-6 w-6 accent-primary" />
        Årligt medlemskab
      </label>

      <label class="flex cursor-pointer items-center gap-2 text-m-p-big lg:text-p-big text-secondary">
        <input type="radio" name="donationstype" value="maanedligt" class="h-6 w-6 accent-primary" />
        Månedligt medlemskab
      </label>
    </div>
  </div>

 <div>
  <p class="mb-3 text-m-p-big lg:text-p-big text-secondary">
    Vælg beløb
  </p>

  <div class="grid grid-cols-3 gap-2">
    <label class="cursor-pointer block">
      <input type="radio" name="belob" value="89" checked class="peer sr-only" />
      <span class="flex h-full min-h-12 items-center justify-center rounded-lg border-2 border-secondary bg-background1 px-4 py-3 text-center text-m-p-big lg:text-p-big text-secondary transition duration-200 hover:bg-secondary hover:text-white peer-checked:bg-secondary peer-checked:text-white">
        89 DKK
      </span>
    </label>

    <label class="cursor-pointer block">
      <input type="radio" name="belob" value="149" class="peer sr-only" />
      <span class="flex h-full min-h-12 items-center justify-center rounded-lg border-2 border-secondary bg-background1 px-4 py-3 text-center text-m-p-big lg:text-p-big text-secondary transition duration-200 hover:bg-secondary hover:text-white peer-checked:bg-secondary peer-checked:text-white">
        149 DKK
      </span>
    </label>

    <label class="cursor-pointer block">
      <input type="radio" name="belob" value="299" class="peer sr-only" />
      <span class="flex h-full min-h-12 items-center justify-center rounded-lg border-2 border-secondary bg-background1 px-4 py-3 text-center text-m-p-big lg:text-p-big text-secondary transition duration-200 hover:bg-secondary hover:text-white peer-checked:bg-secondary peer-checked:text-white">
        299 DKK
      </span>
    </label>
  </div>

  <!-- Andet beløb -->
  <input 
    type="text"
    name="andetbeloeb"
    placeholder="Andet beløb"
    inputmode="numeric"
    class="mt-2 w-full rounded-md border-2 border-secondary bg-background1 px-4 py-3 text-center text-m-p-big lg:text-p-big text-secondary placeholder:text-secondary focus:outline-none"
  />
</div>

  <!-- Betalingstype -->
  <div>
    <p class="mb-3 text-m-p-big lg:text-p-big text-secondary">
      Vælg betalingstype
    </p>

    <div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:gap-6">
      <label class="flex cursor-pointer items-center gap-2 text-m-p-big lg:text-p-big text-secondary">
        <input type="radio" name="payment" value="mobilepay" checked class="h-6 w-6 accent-primary" />
        MobilePay
      </label>

      <label class="flex cursor-pointer items-center gap-2 text-m-p-big lg:text-p-big text-secondary">
        <input type="radio" name="payment" value="kort" class="h-6 w-6 accent-primary" />
        Betalingskort
      </label>
    </div>
  </div>

  <!-- Din knap -->
 <Knap variant="primary2" size="medium" type="button" id="paymentSubmit">
  Videre
</Knap>

</form>

 <!-- Vibecoded med copilot - ikke sikkert det skal bruges -->
<script type="module">
  const paymentButton = document.getElementById('paymentSubmit');
  paymentButton?.addEventListener('click', () => {
    const selectedPayment = document.querySelector('input[name="payment"]:checked');
    const paymentValue = selectedPayment?.value;

    if (paymentValue === 'kort') {
      window.location.href = '/betaling/kort';
      return;
    }

    window.location.href = '/betaling/mobilepay';
  });
</script>
	</section>