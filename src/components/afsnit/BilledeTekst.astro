---
interface Props {
  title: string;
  paragraphs: string[];
  image: string;
  imageAlt: string;
  caption?: string;
  imageClass?: string;
  figureClass?: string;
  textClass?: string;
}

const {
  title,
  paragraphs,
  image,
  imageAlt,
  caption,
  imageClass,
  figureClass,
  textClass,
} = Astro.props;
---

<section class="mx-auto max-w-230 gap-3 px-4 py-10">
  <div
    class="mx-auto grid max-w-5xl grid-cols-1 items-start gap-10 lg:grid-cols-2"
  >
    
    <!-- Billede i venstre side -->
    <figure class={figureClass || "order-1 w-full lg:order-1"}>
      <img
        src={image}
        alt={imageAlt}
        class={`${imageClass || "w-full"} rounded-md object-cover`}
      />

      {
        caption && (
          <figcaption class="font-body text-m-p-small lg:text-p-small text-secondary mt-2 text-right">
            {caption}
          </figcaption>
        )
      }
    </figure>

    <!-- Tekst i højre side -->
    <div class={textClass || "order-2 lg:order-2"}>
      <h2
        class="font-body font-bold text-m-title2 lg:text-title2"
      >
        {title}
      </h2>

      <div
        class="font-body text-m-p-big lg:text-p-big text-secondary space-y-5 leading-relaxed"
      >
        {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>
  </div>
</section>