---
import Link from "../generelt/Link.astro";

const {
  image,
  title = "Projekt",
  text,
  href = "#",
  imageAlt = title,
  class: extraClass = "",
} = Astro.props;
---

<article
  class={`overflow-hidden rounded-sm border border-background1 bg-background2 max-w-sm shadow-sm ${extraClass}`}
>
  <!-- Billede øverst -->
  <img
    src={image}
    alt={imageAlt}
    class="h-56 w-full object-cover"
  />

  <!-- Tekstindhold -->
  <div class="p-6 font-body text-secondary">
    <h3 class="mb-3 font-body text-m-title3 lg:text-title3 font-bold">
      {title}
    </h3>

    <p class="mb-4 text-m-p-big lg:text-p-big leading-relaxed">
      {text}
    </p>

    <Link href={href} variant="textlink" size="small">
      Læs mere →
    </Link>
  </div>
</article>