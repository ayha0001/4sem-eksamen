---
interface Props {
  title: string;
  paragraphs: string[];
  image: string;
  imageAlt: string;
  caption?: string;
  imageClass?: string;
  figureClass?: string;
}

const {
  title,
  paragraphs,
  image,
  imageAlt,
  caption,
  imageClass,
  figureClass,
} = Astro.props;
---

<section class="px-6 py-12 lg:px-12">
  <div class="mx-auto grid max-w-5xl grid-cols-1 gap-10 items-start lg:grid-cols-2">
    
    <div>
      <h2 class="font-body mb-6 text-m-title2 font-bold text-secondary lg:text-title2">
        {title}
      </h2>

      <div class="font-body space-y-5 text-m-p-big leading-relaxed text-secondary lg:text-p-big">
        {paragraphs.map((paragraph) => (
          <p>{paragraph}</p>
        ))}
      </div>
    </div>

    <figure class={figureClass || "w-full"}>
      <img
        src={image}
        alt={imageAlt}
        class={`${imageClass || "w-full"} rounded-md object-cover`}
      />

      {caption && (
        <figcaption class="font-body mt-2 text-right text-m-p-small text-secondary lg:text-p-small">
          {caption}
        </figcaption>
      )}
    </figure>

  </div>
</section>