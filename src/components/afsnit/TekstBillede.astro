---
interface Props {
  title: string;
  paragraphs: string[];
  image: string;
  imageAlt: string;
  caption?: string;
  imageClass?: string;
  figureClass?: string;
}

const { title, paragraphs, image, imageAlt, caption, imageClass, figureClass } =
  Astro.props;
---

<section class="mx-auto max-w-230 px-4 lg:px-4">
  <div class="grid grid-cols-1 items-start gap-10 lg:grid-cols-2">
    <div>
      <h2
        class="font-body text-m-title2 text-secondary lg:text-title2 mb-6 font-bold"
      >
        {title}
      </h2>

      <div
        class="font-body text-m-p-big text-secondary lg:text-p-big space-y-5 leading-relaxed"
      >
        {paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
    </div>

    <figure class={figureClass || "w-full"}>
      <img
        src={image}
        alt={imageAlt}
        class={`${imageClass || "w-full"} rounded-md object-cover`}
      />

      {
        caption && (
          <figcaption class="font-body text-m-p-small text-secondary lg:text-p-small mt-2 text-right">
            {caption}
          </figcaption>
        )
      }
    </figure>
  </div>
</section>
