---
import "../styles/global.css";
import "aos/dist/aos.css";
import Header from "../components/generelt/Header.astro";

const { pagetitle } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{pagetitle} | Hjælp Din Næste</title></head
  >
  <Header />
  <slot />
  <script>
    import AOS from "aos";

    AOS.init({
      once: true,
      duration: 700,
      easing: "ease-out-cubic",
      offset: 80,
    });
  </script>

  <style>
    html,
    body {
      margin: 0;
      width: 100%;
      height: 100%;
    }
  </style>


</html>
